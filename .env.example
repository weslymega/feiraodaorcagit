# ============================================================
# FEIRÃO DA ORCA — Variáveis de Ambiente
# ============================================================
# Copie este arquivo como .env e preencha os valores reais.
# NUNCA commite o .env real — ele está no .gitignore.
# ============================================================

# --- Supabase ---
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...sua_anon_key_aqui

# --- Mercado Pago ---
VITE_MP_PUBLIC_KEY=APP_USR-...sua_chave_publica_aqui

# --- URL do App (Vercel / produção) ---
VITE_APP_URL=https://seu-dominio.vercel.app

# --- Sentry — Observabilidade de Produção ---
# Sentry Dashboard → Project Settings → Client Keys (DSN)
# Deixe em branco para desativar o monitoramento (modo dev)
VITE_SENTRY_DSN=https://XXXXXXXX@oYYYYYYYY.ingest.us.sentry.io/ZZZZZZZZ

# --- Versão do App (usada no release tracking do Sentry) ---
VITE_APP_VERSION=1.1.9
